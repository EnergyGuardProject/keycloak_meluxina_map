# ---- Shared pgdb Postgres (on nginxproxy_energyguard_net) ----
POSTGRES_HOST=pgdb
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_MAINTENANCE_DB=postgres
APP_DB_NAME=keycloak_slurm_map

# ---- Security ----
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=change-me

FRONTEND_SECRET=change-me

# ---- EnergyGuard dashboard DB (read-only: source of truth for teams) ----
# When DASHBOARD_DB_ENABLED=false, GET /users/{username}/token returns 400;
# the team endpoints keep working.
DASHBOARD_DB_ENABLED=true
DASHBOARD_DB_HOST=db
DASHBOARD_DB_PORT=5432
DASHBOARD_DB_NAME=energyguard
DASHBOARD_DB_USER=energyguard_user
DASHBOARD_DB_PASSWORD=change-me
